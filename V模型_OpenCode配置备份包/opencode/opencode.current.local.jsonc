  ],
  "command": {
    "vmodel": {
      "description": "Run the global editable V-model software workflow for the active project",
      "agent": "vmodel",
      "subtask": false,
      "template": "Run the global staged software workflow for the active project:\n\n$ARGUMENTS\n\nUse the loaded global workflow and project profile. Create editable stage artifacts under ./vmodel_runs/<task>/ in the current workspace. Stop at requirement and architecture gates for user review. If the user edited an artifact, read it before continuing. Save one reusable key path only after the complete workflow is accepted."
    },
    "cs-vmodel": {
      "description": "Run the CSWrite project profile through the global editable V-model workflow",
      "agent": "cswrite-vmodel",
      "subtask": false,
      "template": "Run the CSWrite burner software task with the global staged workflow and the CSWrite project profile:\n\n$ARGUMENTS\n\nUse taskpath_memory, kg_rag_neo4j, and codegraph as defined by the project profile. Create editable artifacts under ./vmodel_runs/<task>/ in the current CSWrite workspace. Stop at requirement and architecture gates for user review. Generate software-only tests unless the user explicitly asks otherwise. Save one reusable key path only after the complete workflow is accepted."
    }
  },
  "mcp": {
